# Copy this file to ".env" (same folder) and fill in the values.
# .env is git-ignored, so your secrets never get committed.

# From Meta's WhatsApp > API Setup page
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Make up any random string here yourself — you'll enter the SAME string
# into Meta's webhook setup screen later. It just proves the webhook
# request is really coming from your own Meta app.
WHATSAPP_VERIFY_TOKEN=

# From Meta's App Dashboard > App Settings > Basic > "App secret" (click "Show")
# Used to verify incoming webhook requests are genuinely from Meta.
WHATSAPP_APP_SECRET=

# Your own phone number in international format, e.g. 15551234567 (no "+", no spaces).
# Only messages from this number will be able to create transactions via the bot.
WHATSAPP_ALLOWED_FROM=

# Which account (see Accounts tab, or the API) quick WhatsApp entries and
# scanned receipts should be saved into. Leave blank to use the first account.
WHATSAPP_DEFAULT_ACCOUNT_ID=
